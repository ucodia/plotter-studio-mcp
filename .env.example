# Directory where SVG files are saved
PLOTTER_SVG_DIR=~/plotter-studio/output

# Webhook URL for push notifications (supports ntfy.sh)
PLOTTER_WEBHOOK_URL=

# NextDraw model number (2 = AxiDraw V3/A3)
PLOTTER_MODEL=2

# Pen lift type (3 = brushless servo)
PLOTTER_PENLIFT=3

# Webcam device index
PLOTTER_CAMERA=0
